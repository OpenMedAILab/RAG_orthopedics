# RAG Orthopedics 环境变量配置
# 复制此文件为 .env 并填入实际值

# ==================== LLM API 配置 ====================
# OpenRouter API Key (用于访问 GPT、Gemini、Grok 等模型)
# 获取地址：https://openrouter.ai/
OPEN_ROUTER_KEY=your_openrouter_api_key_here

# 硅基流动 API Key (用于 BAAI/bge-m3 嵌入模型)
# 获取地址：https://siliconflow.cn/
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# ==================== Web 应用配置 ====================
# Flask 密钥 (至少 32 字节，用于 JWT 签名)
# 生成方法：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-at-least-32-bytes-long

# Flask 运行配置
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ==================== RAG 配置 ====================
# FAISS 索引路径
FAISS_INDEX_PATH=NaiveRag/rag_index.faiss

# 元数据路径
META_PATH=NaiveRag/rag_meta.json

# 检索配置
TOP_K=3
RETRIEVE_K=10

# ==================== 其他配置 ====================
# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
